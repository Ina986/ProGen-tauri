{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:read-all",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "opener:default",
    "opener:allow-open-url",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
